# Supply Chain Exception Triage — local dev environment template

# Secret Manager mounted as env vars (e.g. `--set-secrets GEMINI_API_KEY=gemini-key:latest`
# per `.claude/rules/deployment.md` §3). Only non-secret config (project IDs,CORS origins, log settings) goes into Cloud Run's env
# Deployment environment. Used by the pydantic-settings validators in security.md to gate placeholder-secret checks and emulator-host bans.
ENV=dev

# GCP project ID
GCP_PROJECT_ID=

# Firebase project ID — often same as GCP_PROJECT_ID, can differ.
FIREBASE_PROJECT_ID=

# Allowed CORS origins as a JSON array. Wildcards rejected at startup
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

SCT_SECRET__GEMINI_API_KEY=

# Supermemory API key (Sprint 4+ real integration). Optional until then —
# Sprints 0-3 use FakeSupermemoryClient.
SCT_SECRET__SUPERMEMORY_API_KEY=

# Firebase service account JSON content (inline) OR use
# GOOGLE_APPLICATION_CREDENTIALS (below) to point at a file.
# SCT_SECRET__FIREBASE_SERVICE_ACCOUNT=

# Test escape hatch: skip GCP Secret Manager and raise SecretNotFoundError
# when a key isn't in the env fallbacks. Used by unit tests to stay hermetic.
# SCT_DISABLE_SECRET_MANAGER=1

GEMINI_API_KEY=

GOOGLE_CLOUD_LOCATION=global

# =============================================================================
# Firebase Admin SDK (production auth + Firestore)
# =============================================================================

# Path to a service-account JSON for LOCAL dev only. Production uses
# Workload Identity (Cloud Run binds the SA automatically) — do NOT set this
# variable in Cloud Run. Per `.claude/rules/deployment.md` §3.
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# =============================================================================
# Emulators — local dev only (NEVER set in production)
# =============================================================================

# Firestore emulator. When set, `get_firestore_client()` + firebase_admin
# route to it instead of prod. Matches `firebase.json` emulator port.
FIRESTORE_EMULATOR_HOST=localhost:8080

# Firebase Auth emulator. When set, `firebase_admin.auth.verify_id_token()`
# accepts emulator-signed tokens.
#
# DANGER: if this variable is set in a non-dev Cloud Run env, the Admin SDK
# accepts forged tokens. The pydantic-settings validator in security.md §2
# rejects this at startup when ENV != "dev". Never set in staging/prod.
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Consistent project ID for emulator runs. Our pytest fixtures set
# "sct-test"; override here only for manual testing.
# GCLOUD_PROJECT=sct-test
# GOOGLE_CLOUD_PROJECT=sct-test

# =============================================================================
# Logging (read by utils/logging.py at configure time)
# =============================================================================
# See `.claude/rules/logging.md` §8.

# One of: DEBUG, INFO, WARNING, ERROR. Default INFO.
# DEBUG enables Rich's show_locals tracebacks — dev only (PII risk in prod;
# bounded by locals_max_string=80 + locals_max_length=10 even so).
LOG_LEVEL=INFO

# 1 (default): Rich console + 4 rotating file handlers in LOGS_DIR.
# 0:           Rich console + JSON stdout only (Cloud Run captures stdout).
LOG_TO_FILES=1

# Directory for rotating log files. Gitignored. Default: logs/.
LOGS_DIR=logs

# =============================================================================
# Seed data (Sprint 2+)
# =============================================================================
# When scripts/seed_firestore.py --live lands in Sprint 2, it seeds the
# Firestore instance pointed to by FIRESTORE_EMULATOR_HOST (default) or
# production (if unset). No new env var needed today.
